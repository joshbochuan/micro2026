library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use work.adder_package.all;

entity adder8 is
    Port (
		  cin  : in  STD_LOGIC;
        X    : in  STD_LOGIC_VECTOR(7 downto 0);
        Y    : in  STD_LOGIC_VECTOR(7 downto 0);
        S  : out STD_LOGIC_VECTOR(7 downto 0);
        cout : out STD_LOGIC
    );
end adder8;

architecture Structural of adder8 is

    signal C : STD_LOGIC_VECTOR(8 downto 0);

begin

    C(0) <= cin;

    FA0: full_adder port map(C(0), X(0), Y(0), S(0), C(1));
	 FA1: full_adder port map(C(1), X(1), Y(1), S(1), C(2));
	 FA2: full_adder port map(C(2), X(2), Y(2), S(2), C(3));
	 FA3: full_adder port map(C(3), X(3), Y(3), S(3), C(4));
	 FA4: full_adder port map(C(4), X(4), Y(4), S(4), C(5));
	 FA5: full_adder port map(C(5), X(5), Y(5), S(5), C(6));
	 FA6: full_adder port map(C(6), X(6), Y(6), S(6), C(7));
	 FA7: full_adder port map(C(7), X(7), Y(7), S(7), C(8));

    Cout <= C(8);

end Structural;