library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

package sevenseg_pkg is

    function hex_to_7seg(
        x : STD_LOGIC_VECTOR(3 downto 0)
    ) return STD_LOGIC_VECTOR;

end sevenseg_pkg;


package body sevenseg_pkg is

    function hex_to_7seg(
        x : STD_LOGIC_VECTOR(3 downto 0)
    ) return STD_LOGIC_VECTOR is

        type seg_table is array (0 to 15) of STD_LOGIC_VECTOR(6 downto 0);

        constant LUT : seg_table := (
            "0000001", -- 0
            "1001111", -- 1
            "0010010", -- 2
            "0000110", -- 3
            "1001100", -- 4
            "0100100", -- 5
            "0100000", -- 6
            "0001111", -- 7
            "0000000", -- 8
            "0000100", -- 9
            "0001000", -- A
            "1100000", -- B
            "0110001", -- C
            "1000010", -- D
            "0110000", -- E
            "0111000"  -- F
        );

    begin
        return LUT(to_integer(unsigned(x)));
    end function;

end sevenseg_pkg;